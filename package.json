    "alchemy": "^0.35.0",
    "svelte": "^5.56.1",
    "svelte-check": "^4.6.0",
    "typescript": "^5.9.0",
    "vite": "^6.3.5"
  },
  "dependencies": {
    "jose": "^5.9.6"
  }
}
